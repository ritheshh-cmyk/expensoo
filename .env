# ============================================================
# FRONTEND ENVIRONMENT — LOCAL DEVELOPMENT
# ============================================================

# Backend direct URL (bypasses Vite proxy — proxy has IPv6/Node.js issue on this machine)
# Backend CORS allows all localhost:* origins so direct call works fine
VITE_BACKEND_URL=https://backendmobile-4swg.onrender.com

# Production URLs (used in prod builds / deployment)
VITE_PRODUCTION_BACKEND_URL=https://expensoo-app-gu3wg.ondigitalocean.app
VITE_PRODUCTION_WEBSOCKET_URL=https://expensoo-app-gu3wg.ondigitalocean.app

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true

# Cache Configuration
VITE_CACHE_MAX_AGE=3600
VITE_CACHE_VERSION=1.0.0

# UI Configuration
VITE_THEME_PRIMARY_COLOR=#3B82F6
VITE_THEME_SECONDARY_COLOR=#64748B
VITE_THEME_SUCCESS_COLOR=#22C55E
VITE_THEME_WARNING_COLOR=#F59E0B
VITE_THEME_ERROR_COLOR=#EF4444