
import React, { useState } from 'react';
import { Link, useLocation } from 'react-router-dom';
import { Button } from "@/components/ui/button";
import { Badge } from "@/components/ui/badge";
import { Separator } from "@/components/ui/separator";
import { ScrollArea } from "@/components/ui/scroll-area";
import { useAuth } from "@/contexts/AuthContext";
import { cn } from "@/lib/utils";
import {
  LayoutDashboard,
  Smartphone,
  Users,
  Package,
  DollarSign,
  BarChart3,
  Settings,
  HelpCircle,
  ChevronLeft,
  ChevronRight,
  Building2,
  UserCheck,
  ClipboardList,
  Wrench,
  Calculator,
  Shield,
  Bell,
  Clock,
  TrendingUp
} from "lucide-react";

interface ProfessionalSidebarProps {
  open?: boolean;
  collapsed?: boolean;
  onCollapsedChange?: (collapsed: boolean) => void;
  className?: string;
}

export function ProfessionalSidebar({ 
  open = false, 
  collapsed = false, 
  onCollapsedChange,
  className 
}: ProfessionalSidebarProps) {
  const { user, hasAccess } = useAuth();
  const location = useLocation();
  const [expandedGroups, setExpandedGroups] = useState<string[]>(['core']);

  const toggleGroup = (groupId: string) => {
    if (collapsed) return;
    
    setExpandedGroups(prev => 
      prev.includes(groupId) 
        ? prev.filter(id => id !== groupId)
        : [...prev, groupId]
    );
  };

  const isGroupExpanded = (groupId: string) => expandedGroups.includes(groupId);

  const navigationGroups = [
    {
      id: 'core',
      label: 'Core Features',
      icon: LayoutDashboard,
      items: [
        {
          icon: LayoutDashboard,
          label: 'Dashboard',
          href: '/dashboard',
          description: 'Business overview',
          badge: null
        },
        {
          icon: Smartphone,
          label: 'Repairs',
          href: '/repairs',
          description: 'Manage device repairs',
          badge: '23'
        },
        {
          icon: Users,
          label: 'Customers',
          href: '/customers',
          description: 'Customer management',
          badge: null
        },
        {
          icon: Package,
          label: 'Inventory',
          href: '/inventory',
          description: 'Stock management',
          badge: '12'
        }
      ]
    },
    {
      id: 'financial',
      label: 'Financial',
      icon: DollarSign,
      items: [
        {
          icon: DollarSign,
          label: 'Transactions',
          href: '/transactions',
          description: 'Payment records',
          badge: null
        },
        {
          icon: Calculator,
          label: 'Billing',
          href: '/billing',
          description: 'Invoice management',
          badge: null
        },
        {
          icon: TrendingUp,
          label: 'Suppliers',
          href: '/suppliers',
          description: 'Supplier payments',
          badge: null
        }
      ]
    },
    {
      id: 'analytics',
      label: 'Analytics & Reports',
      icon: BarChart3,
      items: [
        {
          icon: BarChart3,
          label: 'Reports',
          href: '/reports',
          description: 'Business analytics',
          badge: null
        },
        {
          icon: Clock,
          label: 'Performance',
          href: '/performance',
          description: 'System metrics',
          badge: null
        }
      ]
    }
  ];

  const adminItems = [
    {
      icon: Settings,
      label: 'Settings',
      href: '/settings',
      description: 'System configuration',
      badge: null
    },
    {
      icon: UserCheck,
      label: 'User Management',
      href: '/users',
      description: 'Manage team access',
      badge: null
    },
    {
      icon: Shield,
      label: 'Security',
      href: '/security',
      description: 'Access control',
      badge: null
    }
  ];

  const supportItems = [
    {
      icon: HelpCircle,
      label: 'Help Center',
      href: '/help',
      description: 'Documentation & support',
      badge: null
    },
    {
      icon: Bell,
      label: 'Notifications',
      href: '/notifications',
      description: 'System alerts',
      badge: '3'
    }
  ];

  const isActive = (href: string) => location.pathname === href;

  return (
    <div className={cn(
      "h-full bg-card border-r transition-all duration-300 flex flex-col",
      collapsed ? "w-16" : "w-64",
      className
    )}>
      {/* Header */}
      <div className="p-4 border-b">
        <div className="flex items-center justify-between">
          {!collapsed && (
            <div className="flex items-center gap-2">
              <Building2 className="h-8 w-8 text-primary" />
              <div>
                <h2 className="font-bold text-lg">CallMeMobiles</h2>
                <p className="text-xs text-muted-foreground">Professional Edition</p>
              </div>
            </div>
          )}
          
          {collapsed && (
            <Building2 className="h-8 w-8 text-primary mx-auto" />
          )}
          
          {onCollapsedChange && (
            <Button
              variant="ghost"
              size="sm"
              className="h-8 w-8 p-0"
              onClick={() => onCollapsedChange(!collapsed)}
            >
              {collapsed ? (
                <ChevronRight className="h-4 w-4" />
              ) : (
                <ChevronLeft className="h-4 w-4" />
              )}
            </Button>
          )}
        </div>
      </div>

      {/* Navigation */}
      <ScrollArea className="flex-1 px-3 py-4">
        <div className="space-y-6">
          {/* User Info */}
          {!collapsed && (
            <div className="px-3 py-2 bg-muted/50 rounded-lg">
              <div className="flex items-center gap-2">
                <div className="w-8 h-8 bg-primary rounded-full flex items-center justify-center">
                  <span className="text-xs font-medium text-primary-foreground">
                    {user?.name?.charAt(0) || 'U'}
                  </span>
                </div>
                <div className="flex-1 min-w-0">
                  <p className="font-medium text-sm truncate">{user?.name}</p>
                  <div className="flex items-center gap-1">
                    <Badge variant="secondary" className="text-xs px-1 py-0">
                      {user?.role}
                    </Badge>
                  </div>
                </div>
              </div>
            </div>
          )}

          {/* Navigation Groups */}
          {navigationGroups.map((group) => (
            <div key={group.id} className="space-y-2">
              {!collapsed && (
                <Button
                  variant="ghost"
                  className="w-full justify-start px-3 py-2 h-auto text-sm font-medium"
                  onClick={() => toggleGroup(group.id)}
                >
                  <group.icon className="h-4 w-4 mr-2" />
                  <span className="flex-1 text-left">{group.label}</span>
                  <ChevronRight className={cn(
                    "h-3 w-3 transition-transform",
                    isGroupExpanded(group.id) && "rotate-90"
                  )} />
                </Button>
              )}
              
              {(isGroupExpanded(group.id) || collapsed) && (
                <div className={cn(
                  "space-y-1",
                  !collapsed && "ml-2 pl-4 border-l"
                )}>
                  {group.items.map((item) => (
                    <Link key={item.href} to={item.href}>
                      <Button
                        variant={isActive(item.href) ? "secondary" : "ghost"}
                        className={cn(
                          "w-full justify-start px-3 py-2 h-auto",
                          collapsed ? "px-0 justify-center" : "text-sm",
                          isActive(item.href) && "bg-primary/10 text-primary"
                        )}
                      >
                        <item.icon className={cn(
                          "h-4 w-4",
                          !collapsed && "mr-3"
                        )} />
                        {!collapsed && (
                          <div className="flex-1 text-left">
                            <div className="font-medium">{item.label}</div>
                            <div className="text-xs text-muted-foreground">
                              {item.description}
                            </div>
                          </div>
                        )}
                        {!collapsed && item.badge && (
                          <Badge variant="secondary" className="text-xs">
                            {item.badge}
                          </Badge>
                        )}
                      </Button>
                    </Link>
                  ))}
                </div>
              )}
            </div>
          ))}

          {/* Admin Section */}
          {hasAccess(['admin', 'owner']) && (
            <>
              <Separator />
              <div className="space-y-1">
                {!collapsed && (
                  <p className="text-xs font-medium text-muted-foreground px-3 py-1">
                    Administration
                  </p>
                )}
                {adminItems.map((item) => (
                  <Link key={item.href} to={item.href}>
                    <Button
                      variant={isActive(item.href) ? "secondary" : "ghost"}
                      className={cn(
                        "w-full justify-start px-3 py-2 h-auto",
                        collapsed ? "px-0 justify-center" : "text-sm",
                        isActive(item.href) && "bg-primary/10 text-primary"
                      )}
                    >
                      <item.icon className={cn(
                        "h-4 w-4",
                        !collapsed && "mr-3"
                      )} />
                      {!collapsed && (
                        <div className="flex-1 text-left">
                          <div className="font-medium">{item.label}</div>
                          <div className="text-xs text-muted-foreground">
                            {item.description}
                          </div>
                        </div>
                      )}
                      {!collapsed && item.badge && (
                        <Badge variant="secondary" className="text-xs">
                          {item.badge}
                        </Badge>
                      )}
                    </Button>
                  </Link>
                ))}
              </div>
            </>
          )}

          {/* Support Section */}
          <Separator />
          <div className="space-y-1">
            {!collapsed && (
              <p className="text-xs font-medium text-muted-foreground px-3 py-1">
                Support
              </p>
            )}
            {supportItems.map((item) => (
              <Link key={item.href} to={item.href}>
                <Button
                  variant={isActive(item.href) ? "secondary" : "ghost"}
                  className={cn(
                    "w-full justify-start px-3 py-2 h-auto",
                    collapsed ? "px-0 justify-center" : "text-sm",
                    isActive(item.href) && "bg-primary/10 text-primary"
                  )}
                >
                  <item.icon className={cn(
                    "h-4 w-4",
                    !collapsed && "mr-3"
                  )} />
                  {!collapsed && (
                    <div className="flex-1 text-left">
                      <div className="font-medium">{item.label}</div>
                      <div className="text-xs text-muted-foreground">
                        {item.description}
                      </div>
                    </div>
                  )}
                  {!collapsed && item.badge && (
                    <Badge variant="destructive" className="text-xs">
                      {item.badge}
                    </Badge>
                  )}
                </Button>
              </Link>
            ))}
          </div>
        </div>
      </ScrollArea>

      {/* Footer */}
      {!collapsed && (
        <div className="p-4 border-t">
          <div className="flex items-center justify-between text-xs text-muted-foreground">
            <span>Version 2.1.0</span>
            <Badge variant="outline" className="text-xs">
              Professional
            </Badge>
          </div>
        </div>
      )}
    </div>
  );
}
