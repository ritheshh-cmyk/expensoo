# Environment Configuration
VITE_BACKEND_URL=https://backendmobile-4swg.onrender.com
VITE_PRODUCTION_BACKEND_URL=https://backendmobile-4swg.onrender.com

# Feature Flags
VITE_ENABLE_ERROR_MONITORING=true
VITE_ENABLE_PERFORMANCE_MONITORING=true

# Cache Configuration
VITE_CACHE_MAX_AGE=3600
VITE_CACHE_VERSION=1.0.0

# Vercel Specific
VERCEL_ENV=production
NODE_ENV=production
